vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

direction: down

style: {
  fill: "#0a0a0f"
}

grid: "" {
  grid-rows: 4
  grid-columns: 2
  grid-gap: 20
  style: { fill: "#0a0a0f"; stroke: "#0a0a0f" }

  # ── Row 1: Consumers | MCP Server ────────────────────────────────────────

  consumers: "Consumers" {
    style: {
      fill: "#0d0d18"
      stroke: "#1e293b"
      border-radius: 8
      font-color: "#64748b"
      font-size: 10
      bold: true
    }

    claude_code: "Claude Code" {
      shape: rectangle
      style: { fill: "#f59e0b"; stroke: "#fcd34d"; font-color: "#ffffff"; border-radius: 6; font-size: 12; bold: true }
    }

    bedrock_agent: "Bedrock Agent" {
      shape: rectangle
      style: { fill: "#f59e0b"; stroke: "#fcd34d"; font-color: "#ffffff"; border-radius: 6; font-size: 12; bold: true }
    }

    sdk_client: "AWS SDK / boto3" {
      shape: rectangle
      style: { fill: "#f59e0b"; stroke: "#fcd34d"; font-color: "#ffffff"; border-radius: 6; font-size: 12; bold: true }
    }
  }

  mcp_server: "MCP Server" {
    style: {
      fill: "#0d0d18"
      stroke: "#1e293b"
      border-radius: 8
      font-color: "#64748b"
      font-size: 10
      bold: true
    }

    mcp: "MCP Server\nmcp/server.py\nLLM selects tool" {
      shape: rectangle
      style: { fill: "#7c3aed"; stroke: "#a78bfa"; font-color: "#f9fafb"; border-radius: 8; font-size: 12; bold: true }
    }
  }

  # ── Row 2: Kendra Tools | Neptune Tools ──────────────────────────────────

  kendra_tools: "Kendra Tools" {
    style: {
      fill: "#0d0d18"
      stroke: "#1e293b"
      border-radius: 8
      font-color: "#64748b"
      font-size: 10
      bold: true
    }

    search_docs: "search_hashicorp_docs\nkeyword + semantic search\nmetadata filters" {
      shape: rectangle
      style: { fill: "#172554"; stroke: "#38bdf8"; font-color: "#f9fafb"; border-radius: 6; font-size: 11; bold: true }
    }

    get_info: "get_index_info\nKendra + Neptune status\ncaller identity" {
      shape: rectangle
      style: { fill: "#172554"; stroke: "#38bdf8"; font-color: "#f9fafb"; border-radius: 6; font-size: 11; bold: true }
    }
  }

  neptune_tools: "Neptune Tools" {
    style: {
      fill: "#0d0d18"
      stroke: "#1e293b"
      border-radius: 8
      font-color: "#64748b"
      font-size: 10
      bold: true
    }

    get_deps: "get_resource_dependencies\nupstream / downstream\nmax_depth 1-5" {
      shape: rectangle
      style: { fill: "#172554"; stroke: "#38bdf8"; font-color: "#f9fafb"; border-radius: 6; font-size: 11; bold: true }
    }

    find_resources: "find_resources_by_type\nlist by type + repository\nopenCypher MATCH" {
      shape: rectangle
      style: { fill: "#172554"; stroke: "#38bdf8"; font-color: "#f9fafb"; border-radius: 6; font-size: 11; bold: true }
    }
  }

  # ── Row 3: Kendra | Neptune ──────────────────────────────────────────────

  kendra_store: "Kendra Store" {
    style: {
      fill: "#0d0d18"
      stroke: "#1e293b"
      border-radius: 8
      font-color: "#64748b"
      font-size: 10
      bold: true
    }

    kendra: "Amazon Kendra\nHashiCorp docs, providers\nissues, discuss, blogs" {
      shape: cylinder
      style: { fill: "#1a0a2e"; stroke: "#a855f7"; font-color: "#d8b4fe"; font-size: 12; bold: true }
    }
  }

  neptune_store: "Neptune Store" {
    style: {
      fill: "#0d0d18"
      stroke: "#1e293b"
      border-radius: 8
      font-color: "#64748b"
      font-size: 10
      bold: true
    }

    neptune: "Amazon Neptune\nTerraform resource DAG\nopenCypher graph" {
      shape: cylinder
      style: { fill: "#1a0a2e"; stroke: "#a855f7"; font-color: "#d8b4fe"; font-size: 12; bold: true }
    }
  }

  # ── Row 4: Docs Ingestion | Graph Ingestion ──────────────────────────────

  ingest_docs: "Docs Ingestion" {
    direction: right
    style: {
      fill: "#0d0d18"
      stroke: "#1e293b"
      border-radius: 8
      font-color: "#64748b"
      font-size: 10
      bold: true
    }

    hashicorp_docs: "HashiCorp Docs\nGitHub repos + feeds" {
      shape: rectangle
      style: { fill: "#1c1917"; stroke: "#a78bfa"; font-color: "#f9fafb"; border-radius: 6; font-size: 11; bold: true }
    }

    docs_pipeline: "Docs Pipeline\nCodeBuild -> S3 -> Kendra" {
      shape: rectangle
      style: { fill: "#0f172a"; stroke: "#0ea5e9"; font-color: "#f9fafb"; border-radius: 6; font-size: 11; bold: true }
    }

    hashicorp_docs -> docs_pipeline: "" {
      style: { stroke: "#a78bfa"; stroke-width: 2 }
    }
  }

  ingest_graph: "Graph Ingestion" {
    direction: right
    style: {
      fill: "#0d0d18"
      stroke: "#1e293b"
      border-radius: 8
      font-color: "#64748b"
      font-size: 10
      bold: true
    }

    tf_configs: "Terraform Configs\nworkspace repos" {
      shape: rectangle
      style: { fill: "#1c1917"; stroke: "#a78bfa"; font-color: "#f9fafb"; border-radius: 6; font-size: 11; bold: true }
    }

    graph_pipeline: "Graph Pipeline\nterraform plan -> rover" {
      shape: rectangle
      style: { fill: "#0f172a"; stroke: "#0ea5e9"; font-color: "#f9fafb"; border-radius: 6; font-size: 11; bold: true }
    }

    tf_configs -> graph_pipeline: "" {
      style: { stroke: "#a78bfa"; stroke-width: 2 }
    }
  }
}

# ── Cross-cell connections ─────────────────────────────────────────────────

# Row 1: Consumers -> MCP (left to right, single edge)
grid.consumers -> grid.mcp_server.mcp: "MCP" {
  style: { stroke: "#fbbf24"; stroke-width: 2; font-color: "#fbbf24"; font-size: 10 }
}

# Row 1 -> Row 2: MCP -> tool groups (straight down each column)
grid.mcp_server.mcp -> grid.kendra_tools.search_docs: "" {
  style: { stroke: "#a78bfa"; stroke-width: 2 }
}
grid.mcp_server.mcp -> grid.kendra_tools.get_info: "" {
  style: { stroke: "#a78bfa"; stroke-width: 2 }
}
grid.mcp_server.mcp -> grid.neptune_tools.get_deps: "" {
  style: { stroke: "#a78bfa"; stroke-width: 2 }
}
grid.mcp_server.mcp -> grid.neptune_tools.find_resources: "" {
  style: { stroke: "#a78bfa"; stroke-width: 2 }
}

# Row 2 -> Row 3: Tools -> Stores (straight down same column)
grid.kendra_tools.search_docs -> grid.kendra_store.kendra: "kendra:query" {
  style: { stroke: "#34d399"; stroke-width: 2; font-color: "#34d399"; font-size: 10 }
}
grid.kendra_tools.get_info -> grid.kendra_store.kendra: "status" {
  style: { stroke: "#34d399"; stroke-width: 2; stroke-dash: 4; font-color: "#34d399"; font-size: 10 }
}
grid.neptune_tools.get_deps -> grid.neptune_store.neptune: "openCypher" {
  style: { stroke: "#34d399"; stroke-width: 2; font-color: "#34d399"; font-size: 10 }
}
grid.neptune_tools.find_resources -> grid.neptune_store.neptune: "openCypher" {
  style: { stroke: "#34d399"; stroke-width: 2; font-color: "#34d399"; font-size: 10 }
}

# Row 4 -> Row 3: Ingestion -> Stores (straight up same column)
grid.ingest_docs.docs_pipeline -> grid.kendra_store.kendra: "index" {
  style: { stroke: "#a855f7"; stroke-width: 2; font-color: "#a855f7"; font-size: 10 }
}
grid.ingest_graph.graph_pipeline -> grid.neptune_store.neptune: "MERGE" {
  style: { stroke: "#a855f7"; stroke-width: 2; font-color: "#a855f7"; font-size: 10 }
}
